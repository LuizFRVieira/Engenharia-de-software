import unittest
from abc import ABC, abstractmethod


# Refactor: o código foi reorganizado em estratégias separadas de desconto.
# Mudança: saiu a lógica com vários if/elif e cada desconto virou uma classe própria.

# Interface comum para todas as estratégias de desconto
class DiscountStrategy(ABC):

    @abstractmethod
    def apply(self, value: float) -> float:
        # Obriga todas as estratégias a terem o método apply()
        pass


# Estratégia 1: sem desconto
class NoDiscount(DiscountStrategy):

    def apply(self, value: float) -> float:
        # Retorna o valor original
        return value


# Estratégia 2: desconto percentual
class PercentageDiscount(DiscountStrategy):

    def __init__(self, percent: float):
        # Guarda a porcentagem do desconto
        self.percent = percent

    def apply(self, value: float) -> float:
        # Aplica o desconto percentual
        return value * (1 - self.percent / 100)


# Estratégia 3: desconto por cupom
class CouponDiscount(DiscountStrategy):

    def __init__(self, amount: float):
        # Guarda o valor do cupom
        self.amount = amount

    def apply(self, value: float) -> float:
        # Subtrai o cupom e não deixa o resultado ficar negativo
        return max(0, value - self.amount)


# Mapeia cada tipo de desconto para sua respectiva classe
_STRATEGIES = {
    'none':        lambda amount: NoDiscount(),
    'percentage':  lambda amount: PercentageDiscount(amount),
    'coupon':      lambda amount: CouponDiscount(amount),
}


# Calculador principal
class DiscountCalculator:

    def __init__(self, policy: str, amount: float = 0):
        # Escolhe a estratégia correta com base na policy recebida
        self._strategy = _STRATEGIES[policy](amount)

    def apply(self, value: float) -> float:
        # Delega o cálculo para a estratégia escolhida
        return self._strategy.apply(value)


# Testes iguais aos das fases Red e Green
class TestDiscountCalculator(unittest.TestCase):

    def test_no_discount(self):
        # Testa se o valor continua igual quando não há desconto
        calc = DiscountCalculator('none')
        self.assertEqual(calc.apply(100.0), 100.0)

    def test_percentage_discount(self):
        # Testa desconto de 10%, esperando 90.0
        calc = DiscountCalculator('percentage', 10)
        self.assertEqual(calc.apply(100.0), 90.0)

    def test_coupon_discount(self):
        # Testa cupom de 20, esperando 80.0
        calc = DiscountCalculator('coupon', 20)
        self.assertEqual(calc.apply(100.0), 80.0)

    def test_coupon_discount_never_negative(self):
        # Testa cupom maior que o valor, esperando 0.0
        calc = DiscountCalculator('coupon', 150)
        self.assertEqual(calc.apply(100.0), 0.0)


# Executa os testes
unittest.main(argv=[''], verbosity=2, exit=False)